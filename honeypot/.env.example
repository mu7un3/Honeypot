# Honeypot configuration — copy this file to .env and fill in your values
# NEVER commit .env with real credentials

# Paths (leave as default unless you move files)
HONEYPOT_BASE_DIR=./
HONEYPOT_LOG_FILE=./honeypot.log
HONEYPOT_MODELS_DIR=./models

# Email alerts (Gmail recommended)
# Create an App Password at: https://support.google.com/accounts/answer/185833
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_app_password_here
RECIPIENT_EMAIL=your_email@gmail.com

# Alert throttling
EMAIL_THROTTLE_SECONDS=300
EMAIL_MAX_PER_HOUR=20

# Concurrency
MAX_HANDLER_THREADS=50

# ML settings
ML_N_CLUSTERS=5
ML_CONTAMINATION=0.1
ML_N_ESTIMATORS=100
ML_TEST_SIZE=0.2
ML_THREAT_RULE_WEIGHT=0.6
